---
import Layout from "@/layouts/main.astro"
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog'))
	.filter(post => !post.data.draft)
	.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

const groupedPosts = posts.reduce((acc, post) => {
	const month = post.data.pubDate.toLocaleDateString('pt-BR', { month: 'long' });
	const year = post.data.pubDate.getFullYear();
	const key = `${year} - ${month}`;
	if (!acc[key]) {
		acc[key] = [];
	}
	acc[key].push(post);
	return acc;
}, {} as Record<string, typeof posts>);
const slugify = (str: string) => str.toLowerCase().replace(/\s+/g, '-').normalize("NFD").replace(/[\u0300-\u036f]/g, "");
const groups = Object.keys(groupedPosts);
---

<Layout>
	<div class="mx-auto max-w-2xl px-6 py-8 relative">
		<header class="mb-8">
			<h1 class="text-4xl font-semibold tracking-tight text-foreground">Blog</h1>
		</header>

		<div class="space-y-8">
			{Object.entries(groupedPosts).map(([group, groupPosts]) => (
				<section id={slugify(group)}>
					<h2 class="mb-2 text-2xl font-bold font-sans text-foreground capitalize tracking-tighter">
						{group}
					</h2>
					<hr class="mb-4 border-foreground/5" />
					<ul class="list-disc list-inside space-y-1 ml-1">
						{groupPosts.map((post) => (
							<li>
								<a 
									href={`/blog/${post.id}`}
									class="text-xl font-medium text-purple-600 visited:text-purple-900/60 hover:text-purple-700 hover:underline underline-offset-4 decoration-purple-600/30 transition-colors"
								>
									{post.data.title}
								</a>
							</li>
						))}
					</ul>
				</section>
			))}
		</div>

		<aside class="hidden xl:block absolute left-full top-0 ml-12 w-64 h-full font-sans">
			<div class="sticky top-24 border-l border-foreground/5 pl-6 py-2">
				<p class="mb-4 text-sm font-semibold font-sans tracking-tight text-foreground leading-none">Nesta página</p>
				<nav>
					<ul class="space-y-3">
						{groups.map((group) => (
							<li>
								<a 
									href={`#${slugify(group)}`}
									class="text-sm font-medium text-muted-foreground hover:text-foreground transition-colors block leading-tight capitalize"
								>
									{group}
								</a>
							</li>
						))}
					</ul>
				</nav>
			</div>
		</aside>
	</div>
</Layout>
