---
import "@/styles/global.css"
import Search from "@/components/Search.astro"

interface Props {
  title?: string
}

const { title } = Astro.props
const siteTitle = "blog.eliasnsz"
const fullTitle = title ? `${title} | ${siteTitle}` : siteTitle
---

<html lang="pt-BR">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />
    <meta
      name="google-site-verification"
      content="xckm92TgmoAHHOzblKo_zJBtqpzRiJ-fFwxsE2rQO6w"
    />

    <!-- Primary Meta Tags -->
    <title>{fullTitle}</title>
    <meta name="title" content={fullTitle} />
    <meta
      name="description"
      content="Blog pessoal de Elias Souza sobre desenvolvimento de software, tecnologia e aprendizados."
    />

    <!-- Canonical URL -->
    <link rel="canonical" href={new URL(Astro.url.pathname, Astro.site)} />

    <!-- Sitemap -->
    <link rel="sitemap" href="/sitemap-index.xml" />

    <!-- Open Graph / Facebook -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={Astro.url} />
    <meta property="og:title" content={fullTitle} />
    <meta
      property="og:description"
      content="Blog pessoal de Elias Souza sobre desenvolvimento de software, tecnologia e aprendizados."
    />
    <meta property="og:image" content={new URL("/favicon.svg", Astro.site)} />

    <!-- Twitter -->
    <meta property="twitter:card" content="summary_large_image" />
    <meta property="twitter:url" content={Astro.url} />
    <meta property="twitter:title" content={fullTitle} />
    <meta
      property="twitter:description"
      content="Blog pessoal de Elias Souza sobre desenvolvimento de software, tecnologia e aprendizados."
    />
    <meta
      property="twitter:image"
      content={new URL("/favicon.svg", Astro.site)}
    />

    <script is:inline>
      const theme = (() => {
        if (
          typeof localStorage !== "undefined" &&
          localStorage.getItem("theme")
        ) {
          return localStorage.getItem("theme")
        }
        if (window.matchMedia("(prefers-color-scheme: dark)").matches) {
          return "dark"
        }
        return "light"
      })()

      if (theme === "light") {
        document.documentElement.classList.remove("dark")
      } else {
        document.documentElement.classList.add("dark")
      }

      window.localStorage.setItem("theme", theme)

      const setupThemeToggle = () => {
        const toggles = document.querySelectorAll(".themeToggle")
        toggles.forEach((toggle) => {
          toggle.addEventListener("click", () => {
            const element = document.documentElement
            element.classList.toggle("dark")
            const isDark = element.classList.contains("dark")
            localStorage.setItem("theme", isDark ? "dark" : "light")
          })
        })
      }

      // Inicializa no carregamento e em cada navegação do Astro
      document.addEventListener("astro:page-load", setupThemeToggle)
      // Fallback para carregamento inicial sem transitions
      document.addEventListener("DOMContentLoaded", setupThemeToggle)
    </script>
  </head>
  <body>
    <header
      class="sticky top-0 z-50 border-b border-foreground/5 bg-background/80 backdrop-blur-md"
    >
      <div
        class="mx-auto flex max-w-2xl items-center justify-between px-6 py-4"
      >
        <a
          href="/"
          class="flex items-center font-sans text-xl font-bold tracking-tighter"
        >
          <span class="text-primary">blog</span>
          <span class="text-foreground">.eliasnsz</span>
        </a>
        <nav
          class="flex items-center gap-4 font-sans text-sm font-medium tracking-tight sm:gap-6"
        >
          <Search />
          <a
            href="/"
            class="group relative hidden text-muted-foreground transition-all duration-300 hover:text-primary sm:block"
          >
            Home
            <span
              class="absolute -bottom-1 left-0 h-0.5 w-0 bg-primary opacity-50 transition-all duration-300 group-hover:w-full"
            ></span>
          </a>
          <a
            href="/sobre"
            class="group relative hidden text-muted-foreground transition-all duration-300 hover:text-primary sm:block"
          >
            Sobre
            <span
              class="absolute -bottom-1 left-0 h-0.5 w-0 bg-primary opacity-50 transition-all duration-300 group-hover:w-full"
            ></span>
          </a>
          <button
            class="themeToggle relative flex h-8 w-8 items-center justify-center rounded-md text-muted-foreground transition-all duration-300 hover:text-foreground"
            aria-label="Alternar tema"
          >
            <svg
              xmlns="http://www.w3.org/2000/svg"
              width="20"
              height="20"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="1.5"
              stroke-linecap="round"
              stroke-linejoin="round"
              class="dark:hidden"
            >
              <circle cx="12" cy="12" r="4"></circle>
              <path d="M12 2v2"></path>
              <path d="M12 20v2"></path>
              <path d="m4.93 4.93 1.41 1.41"></path>
              <path d="m17.66 17.66 1.41 1.41"></path>
              <path d="M2 12h2"></path>
              <path d="M20 12h2"></path>
              <path d="m6.34 17.66-1.41 1.41"></path>
              <path d="m19.07 4.93-1.41 1.41"></path>
            </svg>
            <svg
              xmlns="http://www.w3.org/2000/svg"
              width="20"
              height="20"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="1.5"
              stroke-linecap="round"
              stroke-linejoin="round"
              class="hidden dark:block"
            >
              <path d="M12 3a6 6 0 0 0 9 9 9 9 0 1 1-9-9Z"></path>
            </svg>
          </button>
        </nav>
      </div>
    </header>
    <main class="relative z-10">
      <slot />
    </main>
    <footer
      class="mx-auto mt-12 max-w-2xl border-t border-foreground/5 px-6 py-8 text-center font-sans text-xs tracking-[0.2em] text-muted-foreground opacity-40"
    >
      <p>blog.eliasnsz © {new Date().getFullYear()}</p>
    </footer>
  </body>
</html>
