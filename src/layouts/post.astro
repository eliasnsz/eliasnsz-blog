---
import type { MarkdownHeading } from "astro";
import Layout from "./main.astro";

interface Props {
	title: string;
	description: string;
	pubDate: Date;
	updatedDate?: Date;
	heroImage?: string;
	tags?: string[];
	headings: MarkdownHeading[];
}

const { title, description, pubDate, updatedDate, heroImage, tags, headings } = Astro.props;

const filteredHeadings = headings.filter((h) => h.depth > 1 && h.depth < 4);
---

<Layout title={title}>
	<div class="mx-auto max-w-2xl px-6 py-12 relative">
		<article>
			<header class="mb-8 text-center">
				<div class="mb-2 flex italic items-center justify-center gap-2 text-sm text-muted-foreground">
					<time datetime={pubDate.toISOString()}>
						{
							pubDate.toLocaleDateString('pt-BR', {
								year: 'numeric',
								month: 'long',
								day: 'numeric',
							})
						}
					</time>
				</div>

				<h1 class="mb-4 text-4xl font-semibold tracking-tight text-foreground">{title}</h1>
				
				{description && <p class="text-xl text-muted-foreground">{description}</p>}

				{tags && tags.length > 0 && (
					<div class="mt-4 flex flex-wrap gap-2 justify-center">
						{tags.map((tag) => (
							<span class="rounded-full bg-secondary px-3 py-1 text-xs font-medium text-secondary-foreground">
								#{tag}
							</span>
						))}
					</div>
				)}
			</header>

			{
				heroImage && (
					<img
						src={heroImage}
						alt=""
						class="mb-8 aspect-video w-full rounded-xl object-cover shadow-lg"
					/>
				)
			}

			<div class="prose dark:prose-invert max-w-none">
				<slot />
			</div>
			
			<footer class="mt-12 border-t pt-8">
				<a href="/" class="text-sm font-medium text-primary hover:underline">
					← Voltar para a página inicial
				</a>
			</footer>
		</article>

		{filteredHeadings.length > 0 && (
			<aside class="hidden xl:block absolute left-full top-0 ml-12 w-64 h-full font-sans">
				<div class="sticky top-24 border-l border-foreground/5 pl-6 py-2">
					<p class="mb-4 text-sm font-semibold font-sans tracking-tight text-foreground leading-none">Nesta página</p>
					<nav>
						<ul class="space-y-3">
							{filteredHeadings.map((heading) => (
								<li style={`padding-left: ${(heading.depth - 2) * 1}rem`}>
									<a 
										href={`#${heading.slug}`}
										class="text-sm font-medium text-muted-foreground hover:text-foreground transition-colors block leading-tight"
									>
										{heading.text}
									</a>
								</li>
							))}
						</ul>
					</nav>
				</div>
			</aside>
		)}
	</div>
</Layout>
